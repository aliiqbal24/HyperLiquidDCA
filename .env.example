VITE_API_BASE_URL=http://localhost:8787/api

DATABASE_URL=postgres://user:password@host.neon.tech/hypedca?sslmode=require
HYPEDCA_ENCRYPTION_KEY_BASE64=replace-with-32-byte-base64-key
CRON_SECRET=replace-with-long-random-string

STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_CLOUD_MONTHLY=price_replace_hypedca_cloud_monthly

# Set only when packaging a local test build that should keep localhost API access.
HYPEDCA_INCLUDE_LOCALHOST=false
