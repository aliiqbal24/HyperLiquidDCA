{
  "name": "@hypedca/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node ../../scripts/generate-extension-icons.mjs",
    "build": "tsc -p tsconfig.json && vite build",
    "package": "npm run build && node ../../scripts/package-extension.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hypedca/core": "file:../../packages/core",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
  }
}
