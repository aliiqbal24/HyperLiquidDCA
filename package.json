{
  "name": "hypedca",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @hypedca/core && npm run build -w @hypedca/api && npm run build -w @hypedca/worker && npm run build -w @hypedca/extension",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck -w @hypedca/core && npm run build -w @hypedca/core && npm run typecheck -w @hypedca/api && npm run typecheck -w @hypedca/worker && npm run typecheck -w @hypedca/extension",
    "dev:extension": "npm run dev -w @hypedca/extension",
    "dev:api": "npm run dev -w @hypedca/api",
    "dev:worker": "npm run dev -w @hypedca/worker",
    "setup:stripe": "node scripts/setup-stripe.mjs",
    "setup:secrets": "node scripts/generate-secrets.mjs",
    "setup:db": "node scripts/apply-neon-schema.mjs",
    "check:vercel-env": "node scripts/check-vercel-env.mjs",
    "push:vercel-env": "node scripts/push-vercel-env.mjs",
    "vercel:build:api": "vercel build --prod",
    "vercel:deploy:api": "vercel deploy --prebuilt --prod"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@neondatabase/serverless": "^1.0.2",
    "@types/node": "^22.10.7",
    "pngjs": "^7.0.0",
    "stripe": "^22.3.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
